{
  "name": "@bwthomas/outline-numbering",
  "version": "0.1.0",
  "description": "Framework-agnostic ProseMirror plugin (with Tiptap wrapper) for nested ordered-list numbering with pluggable strategies: alphanumeric (Harvard / Purdue OWL I/A/1/a), decimal, legal, arabic, lower-roman, or custom.",
  "license": "MIT",
  "author": "Blake Thomas <bwthomas@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bwthomas/outline-numbering.git"
  },
  "homepage": "https://github.com/bwthomas/outline-numbering#readme",
  "bugs": {
    "url": "https://github.com/bwthomas/outline-numbering/issues"
  },
  "keywords": [
    "prosemirror",
    "prosemirror-plugin",
    "tiptap",
    "tiptap-extension",
    "outline",
    "numbering",
    "ordered-list",
    "alphanumeric",
    "decimal"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tiptap": {
      "types": "./dist/tiptap.d.ts",
      "import": "./dist/tiptap.js",
      "require": "./dist/tiptap.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "ci": "npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.0.0",
    "prosemirror-state": "^1.0.0",
    "prosemirror-view": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@tiptap/core": { "optional": true }
  },
  "devDependencies": {
    "@tiptap/core": "^3.22.3",
    "prosemirror-model": "^1.25.0",
    "prosemirror-state": "^1.4.0",
    "prosemirror-view": "^1.40.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
